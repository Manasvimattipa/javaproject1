import java.util.*;

public class HotelSystem {
    static boolean rooms[] = new boolean[5];

    static void book(int room) {
        if (!rooms[room]) {
            rooms[room] = true;
            System.out.println("Room Booked");
        } else {
            System.out.println("Already Booked");
        }
    }

    static void cancel(int room) {
        rooms[room] = false;
        System.out.println("Booking Cancelled");
    }

    static void display() {
        for (int i = 0; i < rooms.length; i++) {
            System.out.println("Room " + i + ": " + (rooms[i] ? "Booked" : "Available"));
        }
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        while (true) {
            System.out.println("\n1.Book 2.Cancel 3.Display 4.Exit");
            int ch = sc.nextInt();

            switch (ch) {
                case 1:
                    book(sc.nextInt());
                    break;
                case 2:
                    cancel(sc.nextInt());
                    break;
                case 3:
                    display();
                    break;
                case 4:
                    System.exit(0);
            }
        }
    }
}
